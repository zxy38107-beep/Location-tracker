{
  "name": "home-tracker",
  "version": "1.0.0",
  "description": "A lightweight desktop app that notifies you when you arrive home.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync"
  },
  "author": "You",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "@capacitor/cli": "^6.0.0"
  },
  "build": {
    "appId": "com.yourname.hometracker",
    "productName": "Home Tracker",
    "publish": null,
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "script.js"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
